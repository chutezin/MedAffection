{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/doe",
      "has": [
        {
          "type": "host",
          "value": "medaffection.com"
        }
      ],
      "destination": "https://doe.medaffection.com",
      "permanent": false
    },
    {
      "source": "/doe",
      "has": [
        {
          "type": "host",
          "value": "www.medaffection.com"
        }
      ],
      "destination": "https://doe.medaffection.com",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "doe.medaffection.com"
        }
      ],
      "destination": "/doe.html"
    }
  ]
}


